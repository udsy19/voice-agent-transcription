{
  "name": "muse",
  "version": "1.0.0",
  "description": "Voice dictation desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.muse.app",
    "productName": "Muse",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"],
      "icon": "assets/muse.icns",
      "darkModeSupport": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Muse needs microphone access to transcribe your speech.",
        "NSAppleEventsUsageDescription": "Muse needs this to detect the active app and paste text."
      }
    },
    "extraResources": [
      {
        "from": "..",
        "to": "python",
        "filter": ["*.py", "requirements.txt", ".env.example"]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "ui/**/*",
      "assets/**/*"
    ],
    "asar": false
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
